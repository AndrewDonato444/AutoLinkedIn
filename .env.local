GOJIBERRY_API_URL=https://ext.gojiberry.ai
GOJIBERRY_MCP_URL=https://mcp.gojiberry.ai

# ----------------------------------------------------------
# Automation Settings
# ----------------------------------------------------------
DAILY_LEAD_SCAN_LIMIT=50
MIN_INTENT_SCORE=60
ICP_DESCRIPTION=

# ----------------------------------------------------------
# Scheduling
# ----------------------------------------------------------
DAILY_SCAN_CRON="0 8 * * *"
WEEKLY_REPORT_CRON="0 9 * * 1"

# ----------------------------------------------------------
# Build Loop Configuration
# ----------------------------------------------------------
CLI_PROVIDER=claude
MAX_FEATURES=15
MAX_RETRIES=3
BRANCH_STRATEGY=sequential

# Model Selection — Opus for spec, Sonnet for everything else
SPEC_MODEL=claude-opus-4-6
BUILD_MODEL=claude-sonnet-4-6
REFACTOR_MODEL=claude-sonnet-4-6
RETRY_MODEL=claude-sonnet-4-6
DRIFT_MODEL=claude-sonnet-4-6
COMPOUND_MODEL=claude-sonnet-4-6

# Build verification
DRIFT_CHECK=true
MAX_DRIFT_RETRIES=2
REFACTOR=true
COMPOUND=true

# Build verification commands (configured by GojiBerry API Client feature)
BUILD_CHECK_CMD=npx tsc --noEmit
TEST_CHECK_CMD=npm test
LINT_CHECK_CMD=skip
MIGRATION_CMD=skip
E2E_CHECK_CMD=skip

# Transient error handling
RATE_LIMIT_BACKOFF=60
RATE_LIMIT_MAX_WAIT=18000
